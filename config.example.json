{
  "port": 3210,
  "headless": false,
  "maxSessions": 20,
  "pagePoolSize": 4,
  "cdpPort": 9222,
  "attachmentPrompt": "Please respond to the attached content.",
  "providers": {
    "chatgpt": {
      "enabled": true,
      "ephemeral": true
    },
    "claude": {
      "enabled": false,
      "ephemeral": true
    }
  },
  "account": {
    "name": "default",
    "storageStatePath": "./.llm-web-proxy/accounts/default.json"
  },
  "timeouts": {
    "navigation": 30000,
    "responseBase": 30000,
    "responsePerKB": 2000,
    "stability": 2000
  },
  "sseKeepaliveSec": 30,
  "orphanGraceSec": 14400
}
